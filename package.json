{
  "name": "dschang-signal-fe",
  "private": true,
  "version": "0.0.0",
  "description": "Dschang's Signal is a web application where citizens report urban problems (broken traffic lights, potholes, fallen trees, etc.) and city administrators review, accept, and track their resolution. This repository contains the React SPA frontend",
  "type": "module",
  "scripts": {
    "generate-api": "openapi-generator-cli generate -i openapi.yaml -g typescript-fetch -o src/api",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@tailwindcss/vite": "^4.2.1",
    "formik": "^2.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-router": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
